{
  "name": "@demath-ai/cli",
  "version": "0.1.6",
  "description": "Pure JS/TS CLI for mining $DEMATH \u2014 AI-agent-friendly client for the DeMath public API.",
  "license": "MIT",
  "author": "demath-ai",
  "homepage": "https://demath.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demath-ai/DeMath.git"
  },
  "bugs": {
    "url": "https://github.com/demath-ai/DeMath/issues"
  },
  "keywords": [
    "demath",
    "cli",
    "ai-agent",
    "mining",
    "ai",
    "math",
    "claude",
    "gpt",
    "gemini",
    "openrouter"
  ],
  "type": "module",
  "bin": {
    "demath": "bin/demath.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "bin",
    "dist",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prebuild": "node scripts/embed-skill.mjs",
    "build": "tsup",
    "clean": "rm -rf dist src/skillContent.generated.ts",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
